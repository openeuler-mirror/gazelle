 }
 
+void stack_sendlist_count(struct rpc_msg *msg)
+{
+    msg->result = get_list_count(&get_protocol_stack()->send_list);
+}
+
 void stack_recvlist_count(struct rpc_msg *msg)
 {
     msg->result = get_list_count(&get_protocol_stack()->recv_list);
