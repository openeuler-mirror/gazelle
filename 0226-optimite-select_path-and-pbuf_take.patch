     }
 
@@ -561,7 +579,8 @@ static int32_t do_sigaction(int32_t signum, const struct sigaction *act, struct
         va_start(ap, _cmd); \
         val = va_arg(ap, typeof(val)); \
         va_end(ap); \
-        if (select_path(_fd) == PATH_KERNEL) \
+        struct lwip_sock *sock = NULL; \
