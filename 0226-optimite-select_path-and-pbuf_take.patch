@@ -508,7 +526,7 @@ static inline int32_t do_close(int32_t s)
         return lstack_epoll_close(s);
     }
 
-    if (select_path(s) == PATH_KERNEL) {
+    if (select_path(s, &sock) == PATH_KERNEL) {
