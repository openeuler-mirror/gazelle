-        sock->wakeup->stat.app_write_cnt++;
-        if (sock->wakeup->type == WAKEUP_EPOLL && (sock->events & EPOLLOUT)) {
-            del_data_out_event(sock);
-        }
+    pbufs[0]->last = pbufs[write_num - 1];
+    sock->remain_len = 0;
+    free(pbufs);
+    return send_len;
+}
