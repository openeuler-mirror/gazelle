-        if (ret < 0) {
-            LSTACK_EXIT(1, "dpdk_eal_init failed ret=%d errno=%d\n", ret, errno);
-        }
-
-        ret = pthread_create(&tid, NULL, (void *(*)(void *))control_server_thread, NULL);
