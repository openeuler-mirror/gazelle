 static struct pbuf *pbuf_free_partial(struct pbuf *pbuf, uint16_t free_len)
 {
+    uint16_t tot_len = pbuf->tot_len - free_len;
+
     while (free_len && pbuf) {
         if (free_len >= pbuf->len) {
-            struct pbuf *p = pbuf;
