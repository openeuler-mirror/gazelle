+#define PRINT_SERVER(format, ...)           do \
+                                            { \
+                                                printf("<server>: "); \
+                                                printf(format, ##__VA_ARGS__); \
+                                                printf("\n"); \
+                                            } while(0)
+#define PRINT_CLIENT(format, ...)           do \
+                                            { \
+                                                printf("<client>: "); \
+                                                printf(format, ##__VA_ARGS__); \
+                                                printf("\n"); \
+                                            } while(0)
